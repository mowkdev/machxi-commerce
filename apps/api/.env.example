NODE_ENV=development
PORT=3001
LOG_LEVEL=info
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/machxi_commerce
CORS_ORIGIN=http://localhost:5175

# Auth.js — required (must be at least 32 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=replace-me-with-a-random-32+-char-secret
AUTH_URL=http://localhost:3001/api/auth
AUTH_TRUST_HOST=true

# Object storage (S3-compatible). Local dev points at MinIO from docker-compose.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=machxi-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_URL=http://localhost:9000/machxi-media
MEDIA_MAX_BYTES=26214400
